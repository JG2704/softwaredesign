Project ia_detector {
  database_type: "PostgreSQL"
  Note: "Database model for IA Detector MVP. Supports users, verification cases, evidence, risk signals, uploaded files, audit logs, refresh tokens and fact-check cache."
}

/* =========================
   ENUMS
========================= */

Enum user_role {
  JOURNALIST
  ADMIN
}

Enum user_status {
  ACTIVE
  DISABLED
}

Enum verification_input_type {
  TEXT
  URL
  IMAGE
}

Enum verification_status {
  CREATED
  PROCESSING
  PASS
  NO_PASS
  HUMAN_REVIEW
  FAILED
}

Enum source_agreement {
  HIGH
  MEDIUM
  LOW
}

Enum risk_severity {
  LOW
  MEDIUM
  HIGH
}

Enum risk_signal_type {
  NO_SOURCE
  EMOTIONAL_LANGUAGE
  CONTRADICTORY_EVIDENCE
  LOW_SOURCE_AGREEMENT
  OCR_UNCERTAINTY
  PROVIDER_UNAVAILABLE
}

Enum audit_event_type {
  USER_LOGIN
  USER_LOGOUT
  VERIFICATION_CREATED
  CLAIM_EXTRACTED
  EVIDENCE_SEARCH_COMPLETED
  RISK_ANALYSIS_COMPLETED
  AI_DECISION_COMPLETED
  VERIFICATION_FAILED
  IMAGE_UPLOADED
  HISTORY_OPENED
  AUDIT_LOG_VIEWED
}

/* =========================
   USERS
========================= */

Table users {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email varchar(255) [not null, unique]
  name varchar(150) [not null]
  password_hash text [not null]
  role user_role [not null, default: 'JOURNALIST']
  status user_status [not null, default: 'ACTIVE']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  deleted_at timestamp

  indexes {
    email [unique, name: "users_email_unique"]
    role [name: "users_role_idx"]
  }

  Note: "Stores IA Detector users. Passwords must be stored as hashes only."
}

/* =========================
   REFRESH TOKENS
========================= */

Table refresh_tokens {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token_hash text [not null]
  expires_at timestamp [not null]
  revoked_at timestamp
  created_at timestamp [not null, default: `now()`]

  indexes {
    user_id [name: "refresh_tokens_user_id_idx"]
    token_hash [name: "refresh_tokens_token_hash_idx"]
  }

  Note: "Stores hashed refresh tokens. Raw tokens must never be stored."
}

/* =========================
   UPLOADED FILES
========================= */

Table uploaded_files {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  owner_user_id uuid [not null]
  original_file_name varchar(255) [not null]
  mime_type varchar(100) [not null]
  size_bytes int [not null]
  storage_path text [not null]
  sha256_hash varchar(64) [not null]
  created_at timestamp [not null, default: `now()`]
  deleted_at timestamp

  indexes {
    owner_user_id [name: "uploaded_files_owner_idx"]
    sha256_hash [name: "uploaded_files_hash_idx"]
  }

  Note: "Stores metadata for images or screenshots. File content is stored locally under /storage/uploads for MVP."
}

/* =========================
   VERIFICATION CASES
========================= */

Table verification_cases {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  input_type verification_input_type [not null]
  raw_input text
  uploaded_file_id uuid
  extracted_claim text
  status verification_status [not null, default: 'CREATED']
  evidence_score int
  risk_score int
  source_agreement source_agreement
  decision_reason text
  error_code varchar(100)
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  completed_at timestamp

  indexes {
    (user_id, created_at) [name: "verification_cases_user_created_idx"]
    status [name: "verification_cases_status_idx"]
    uploaded_file_id [name: "verification_cases_file_idx"]
  }

  Note: "Main verification record. Final status must be PASS, NO_PASS, HUMAN_REVIEW, or FAILED. Never TRUE/FALSE."
}

/* =========================
   EVIDENCE RESULTS
========================= */

Table evidence_results {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  verification_case_id uuid [not null]
  source_name varchar(255) [not null]
  title text [not null]
  url text [not null]
  rating varchar(255)
  claim_reviewed text
  relevance_score int [not null]
  published_at timestamp
  provider varchar(100) [not null]
  created_at timestamp [not null, default: `now()`]

  indexes {
    verification_case_id [name: "evidence_case_idx"]
    url [name: "evidence_url_idx"]
    provider [name: "evidence_provider_idx"]
  }

  Note: "Stores evidence found for one verification case. Evidence contributes to scoring but does not decide final classification alone."
}

/* =========================
   RISK SIGNALS
========================= */

Table risk_signals {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  verification_case_id uuid [not null]
  type risk_signal_type [not null]
  severity risk_severity [not null]
  description text [not null]
  created_at timestamp [not null, default: `now()`]

  indexes {
    verification_case_id [name: "risk_signals_case_idx"]
    type [name: "risk_signals_type_idx"]
  }

  Note: "Stores structured risk indicators shown on the result page."
}

/* =========================
   AUDIT LOGS
========================= */

Table audit_logs {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid
  verification_case_id uuid
  event_type audit_event_type [not null]
  trace_id varchar(100) [not null]
  metadata jsonb
  created_at timestamp [not null, default: `now()`]

  indexes {
    verification_case_id [name: "audit_case_idx"]
    user_id [name: "audit_user_idx"]
    trace_id [name: "audit_trace_idx"]
    event_type [name: "audit_event_type_idx"]
  }

  Note: "Append-only audit table. Must not store secrets, API keys, passwords or refresh tokens."
}

/* =========================
   FACT CHECK CACHE
========================= */

Table fact_check_cache {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  cache_key varchar(255) [not null]
  normalized_claim text [not null]
  provider varchar(100) [not null]
  response_data jsonb [not null]
  expires_at timestamp [not null]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  indexes {
    cache_key [unique, name: "fact_check_cache_key_unique"]
    expires_at [name: "fact_check_cache_expires_idx"]
    provider [name: "fact_check_cache_provider_idx"]
  }

  Note: "Database-backed cache for repeated fact-check queries. MVP TTL is 60 minutes."
}

/* =========================
   RELATIONSHIPS
========================= */

Ref: refresh_tokens.user_id > users.id

Ref: uploaded_files.owner_user_id > users.id

Ref: verification_cases.user_id > users.id

Ref: verification_cases.uploaded_file_id > uploaded_files.id

Ref: evidence_results.verification_case_id > verification_cases.id

Ref: risk_signals.verification_case_id > verification_cases.id

Ref: audit_logs.user_id > users.id

Ref: audit_logs.verification_case_id > verification_cases.id