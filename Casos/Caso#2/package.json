{
  "name": "caso2-ia-detector",
  "version": "1.0.0",
  "description": "IA Detector is an editorial verification assistant for journalists and editorial teams.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "ts-node-dev --respawn --transpile-only --project tsconfig.backend.json src/backend/main.ts",
    "build:frontend": "vite build",
    "preview:frontend": "vite preview",
    "typecheck:frontend": "tsc --project tsconfig.frontend.json --noEmit",
    "test:frontend": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "validate": "prisma format && prisma validate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SantiagoCaldeZ/caso2-ia-detector.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SantiagoCaldeZ/caso2-ia-detector/issues"
  },
  "homepage": "https://github.com/SantiagoCaldeZ/caso2-ia-detector#readme",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.20.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "react-router-dom": "^7.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
