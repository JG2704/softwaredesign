generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* =========================
   ENUMS
========================= */

enum UserRole {
  JOURNALIST
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum VerificationInputType {
  TEXT
  URL
  IMAGE
}

enum VerificationStatus {
  CREATED
  PROCESSING
  PASS
  NO_PASS
  HUMAN_REVIEW
  FAILED
}

enum SourceAgreement {
  HIGH
  MEDIUM
  LOW
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RiskSignalType {
  NO_SOURCE
  EMOTIONAL_LANGUAGE
  CONTRADICTORY_EVIDENCE
  LOW_SOURCE_AGREEMENT
  OCR_UNCERTAINTY
  PROVIDER_UNAVAILABLE
}

enum AuditEventType {
  USER_LOGIN
  USER_LOGOUT
  VERIFICATION_CREATED
  CLAIM_EXTRACTED
  EVIDENCE_SEARCH_COMPLETED
  RISK_ANALYSIS_COMPLETED
  AI_DECISION_COMPLETED
  VERIFICATION_FAILED
  IMAGE_UPLOADED
  HISTORY_OPENED
  AUDIT_LOG_VIEWED
}

/* =========================
   MODELS
========================= */

model User {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String      @unique @db.VarChar(255)
  name         String      @db.VarChar(150)
  passwordHash String      @map("password_hash")
  role         UserRole    @default(JOURNALIST)
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  refreshTokens     RefreshToken[]
  uploadedFiles     UploadedFile[]
  verificationCases VerificationCase[]
  auditLogs         AuditLog[]

  @@index([role], map: "users_role_idx")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "refresh_tokens_user_id_idx")
  @@index([tokenHash], map: "refresh_tokens_token_hash_idx")
  @@map("refresh_tokens")
}

model UploadedFile {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId      String    @map("owner_user_id") @db.Uuid
  originalFileName String    @map("original_file_name") @db.VarChar(255)
  mimeType         String    @map("mime_type") @db.VarChar(100)
  sizeBytes        Int       @map("size_bytes")
  storagePath      String    @map("storage_path")
  sha256Hash       String    @map("sha256_hash") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  owner             User               @relation(fields: [ownerUserId], references: [id])
  verificationCases VerificationCase[]

  @@index([ownerUserId], map: "uploaded_files_owner_idx")
  @@index([sha256Hash], map: "uploaded_files_hash_idx")
  @@map("uploaded_files")
}

model VerificationCase {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                 @map("user_id") @db.Uuid
  inputType       VerificationInputType  @map("input_type")
  rawInput        String?                @map("raw_input")
  uploadedFileId  String?                @map("uploaded_file_id") @db.Uuid
  extractedClaim  String?                @map("extracted_claim")
  status          VerificationStatus     @default(CREATED)
  evidenceScore   Int?                   @map("evidence_score")
  riskScore       Int?                   @map("risk_score")
  sourceAgreement SourceAgreement?       @map("source_agreement")
  decisionReason  String?                @map("decision_reason")
  errorCode       String?                @map("error_code") @db.VarChar(100)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  completedAt     DateTime?              @map("completed_at")

  user         User          @relation(fields: [userId], references: [id])
  uploadedFile UploadedFile? @relation(fields: [uploadedFileId], references: [id])

  evidenceResults EvidenceResult[]
  riskSignals     RiskSignal[]
  auditLogs       AuditLog[]

  @@index([userId, createdAt], map: "verification_cases_user_created_idx")
  @@index([status], map: "verification_cases_status_idx")
  @@index([uploadedFileId], map: "verification_cases_file_idx")
  @@map("verification_cases")
}

model EvidenceResult {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationCaseId String   @map("verification_case_id") @db.Uuid
  sourceName         String   @map("source_name") @db.VarChar(255)
  title              String
  url                String
  rating             String?  @db.VarChar(255)
  claimReviewed      String?  @map("claim_reviewed")
  relevanceScore     Int      @map("relevance_score")
  publishedAt        DateTime? @map("published_at")
  provider           String   @db.VarChar(100)
  createdAt          DateTime @default(now()) @map("created_at")

  verificationCase VerificationCase @relation(fields: [verificationCaseId], references: [id], onDelete: Cascade)

  @@index([verificationCaseId], map: "evidence_case_idx")
  @@index([url], map: "evidence_url_idx")
  @@index([provider], map: "evidence_provider_idx")
  @@unique([verificationCaseId, url], map: "evidence_case_url_unique")
  @@map("evidence_results")
}

model RiskSignal {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationCaseId String         @map("verification_case_id") @db.Uuid
  type               RiskSignalType
  severity           RiskSeverity
  description        String
  createdAt          DateTime       @default(now()) @map("created_at")

  verificationCase VerificationCase @relation(fields: [verificationCaseId], references: [id], onDelete: Cascade)

  @@index([verificationCaseId], map: "risk_signals_case_idx")
  @@index([type], map: "risk_signals_type_idx")
  @@map("risk_signals")
}

model AuditLog {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String?        @map("user_id") @db.Uuid
  verificationCaseId String?        @map("verification_case_id") @db.Uuid
  eventType          AuditEventType @map("event_type")
  traceId            String         @map("trace_id") @db.VarChar(100)
  metadata           Json?
  createdAt          DateTime       @default(now()) @map("created_at")

  user             User?             @relation(fields: [userId], references: [id])
  verificationCase VerificationCase? @relation(fields: [verificationCaseId], references: [id], onDelete: Cascade)

  @@index([verificationCaseId], map: "audit_case_idx")
  @@index([userId], map: "audit_user_idx")
  @@index([traceId], map: "audit_trace_idx")
  @@index([eventType], map: "audit_event_type_idx")
  @@map("audit_logs")
}

model FactCheckCache {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cacheKey        String   @unique(map: "fact_check_cache_key_unique") @map("cache_key") @db.VarChar(255)
  normalizedClaim String   @map("normalized_claim")
  provider        String   @db.VarChar(100)
  responseData    Json     @map("response_data")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([expiresAt], map: "fact_check_cache_expires_idx")
  @@index([provider], map: "fact_check_cache_provider_idx")
  @@map("fact_check_cache")
}generator client {
  provider = "prisma-client-js"
}